    if (is.null(net_env$net)) { gmessage("Load data first."); return() }
    m <- svalue(dd_si)
    if (m=="none") { gmessage("Skipping SI."); return() }
    sm <- try(surro_index_train(net_env$net, method = m), silent=TRUE)
    if (inherits(sm,"try-error")) { gmessage("SI training failed"); return() }
    net_env$net <- augment_network_with_SI(net_env$net, sm)
    gmessage("SI trained and applied.")
  })

  pg_mod <- ggroup(container = nb, label = "Model")
  gl3 <- gformlayout(container = pg_mod)
  dd_engine <- gcombobox(c("bayes","freq"), label="Engine", container = gl3)
  dd_bayes  <- gcombobox(c("mcmc","vi"), label="Bayes method", container = gl3)
  dd_incon  <- gcombobox(c("none","random"), label="Inconsistency", container = gl3)
  dd_incon_on<- gcombobox(c("T","S","both"), label="Inc on", container = gl3)
  cb_class  <- gcheckbox(text="Class-specific surrogacy", checked=TRUE, container = pg_mod)
  cb_global <- gcheckbox(text="Global surrogacy instead", checked=FALSE, container = pg_mod)
  e_seed    <- gedit("1", container = gl3, label="Seed")
  btn_run   <- gbutton("Run analysis", container = pg_mod)
  logbox <- gtext("", container = pg_mod, expand = TRUE, fill=TRUE)
  fit_env <- new.env(parent=emptyenv())
  addHandlerChanged(btn_run, handler = function(h,...) {
    if (is.null(net_env$net)) { gmessage("Load data first."); return() }
    cat("Running...\n", file = logbox)
    flush.console()
    fit <- try(surro_nma(
      net_env$net,
      engine = svalue(dd_engine),
      bayes_method = svalue(dd_bayes),
      inconsistency = svalue(dd_incon),
      inc_on = svalue(dd_incon_on),
      class_specific = svalue(cb_class),
      global_surrogacy = svalue(cb_global),
      seed = as.integer(svalue(e_seed))
    ), silent=TRUE)
    if (inherits(fit,"try-error")) { gmessage("Fit failed."); return() }
    fit_env$fit <- fit
    cat("Done.\n", file = logbox, append = TRUE)
  })

  pg_res <- ggroup(container = nb, label = "Results", horizontal = FALSE)
  btn_summ <- gbutton("Show summary table", container = pg_res)
  tbl <- gtable(data.frame(), container = pg_res, expand = TRUE, fill = TRUE)
  addHandlerClicked(btn_summ, handler = function(h,...) {
    if (is.null(fit_env$fit)) { gmessage("Run model first."); return() }
    sm <- summarize_treatments(fit_env$fit)
    tbl[] <- sm
  })
  btn_export <- gbutton("Export CINeMA CSV", container = pg_res)
  addHandlerClicked(btn_export, handler = function(...) {
    if (is.null(fit_env$fit)) { gmessage("Run model first."); return() }
    f <- gfile("cinema.csv", type="save")
    if (nzchar(f)) export_cinema(fit_env$fit, file = f)
  })

  pg_plot <- ggroup(container = nb, label = "Plots", horizontal = FALSE)
  btn_p1 <- gbutton("Plot rankogram", container = pg_plot)
  btn_p2 <- gbutton("Plot surrogacy", container = pg_plot)
  btn_p3 <- gbutton("Plot network", container = pg_plot)
  addHandlerClicked(btn_p1, handler = function(...) if (!is.null(fit_env$fit)) print(plot_rankogram(fit_env$fit)))
  addHandlerClicked(btn_p2, handler = function(...) if (!is.null(fit_env$fit)) print(plot_surrogacy(fit_env$fit)))
  addHandlerClicked(btn_p3, handler = function(...) if (!is.null(net_env$net)) plot_networks(net_env$net))

  pg_diag <- ggroup(container = nb, label = "Diagnostics", horizontal=FALSE)
  btn_ppc <- gbutton("PPC (Bayes only)", container = pg_diag)
  addHandlerClicked(btn_ppc, handler = function(...) if (!is.null(fit_env$fit) && fit_env$fit$engine=="bayes") print(pp_check(fit_env$fit)))
  btn_ns  <- gbutton("Node-splitting (first pair)", container = pg_diag)
  addHandlerClicked(btn_ns, handler = function(...) {
    if (is.null(fit_env$fit)) { gmessage("Run model first."); return() }
    ns <- try(nodesplit_analysis(fit_env$fit$net, engine = fit_env$fit$engine), silent=TRUE)
    print(ns)
  })
  btn_ste <- gbutton("STE plot", container = pg_diag)
  addHandlerClicked(btn_ste, handler = function(...) if (!is.null(fit_env$fit)) print(plot_ste(surrogacy_diagnostics(fit_env$fit))))

  pg_rep <- ggroup(container = nb, label = "Report")
  e_author <- gedit("Analyst", container = pg_rep)
  e_title  <- gedit("surroNMA Analysis", container = pg_rep)
  dd_fmt   <- gcombobox(c("html","pdf"), container = pg_rep)
  btn_rep  <- gbutton("Export report", container = pg_rep)
  addHandlerClicked(btn_rep, handler = function(...) {
    if (is.null(fit_env$fit)) { gmessage("Run model first."); return() }
    f <- gfile("surroNMA_report.html", type="save")
    if (nzchar(f)) export_report(fit_env$fit, file = f, author = svalue(e_author), title=svalue(e_title), format = svalue(dd_fmt))
  })

  visible(w) <- TRUE
  invisible(w)
}

