.suro_require <- function(pkgs, quietly = TRUE) {
  miss <- pkgs[!vapply(pkgs, requireNamespace, quietly = quietly, FUN.VALUE = logical(1))]
  if (length(miss)) {
    message("The following packages are suggested but not installed: ",
            paste(miss, collapse = ", "),
            "\nInstall them via install.packages(...) (or tools::pak()) as needed.")
    return(invisible(FALSE))
  }
  invisible(TRUE)
}

cmdstan_check <- function() {
  if (!requireNamespace("cmdstanr", quietly = TRUE)) return(FALSE)
  cs <- try(cmdstanr::cmdstan_version(), silent = TRUE)
  isTRUE(!inherits(cs, "try-error"))
}
