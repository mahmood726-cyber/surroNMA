# ---------------- Simulator ----------------
#' @export
simulate_surro_data <- function(K=5, J=20, per_study=1, alpha=0.0, beta=0.8, tauS=0.2, tauT=0.3,
                                sigma_d=0.4, classes = NULL, seed=1) {
  set.seed(seed)
  if (is.null(classes)) classes <- paste0("C", seq_len(K))
  trts <- paste0("T", seq_len(K))
  n <- J*per_study
  A <- sample(trts, n, TRUE); B <- sample(trts, n, TRUE)
  B[B==A] <- sample(trts[trts!=A[which(B==A)]], sum(B==A), TRUE)
  study <- rep(seq_len(J), each=per_study)
  dS <- c(0, stats::rnorm(K-1, 0, 0.3))
  dT <- c(0, stats::rnorm(K-1, 0, 0.3))
  uS <- stats::rnorm(J, 0, tauS)
  uT <- stats::rnorm(J, 0, tauT)
  map <- setNames(seq_len(K), trts)
  s_eff <- (dS[map[A]] - dS[map[B]]) + uS[study] + stats::rnorm(n, 0, 0.1)
  s_se  <- rep(0.1, n)
  t_obs <- stats::rbinom(n, 1, 0.7)==1
  t_mu  <- (alpha + beta * ((dS[map[A]] - dS[map[B]]) + uS[study])) + stats::rnorm(n, 0, sigma_d)
  t_eff <- ifelse(t_obs, t_mu + stats::rnorm(n,0,0.15), NA_real_)
  t_se  <- ifelse(t_obs, 0.15, NA_real_)
  data.frame(study=study, trt=A, comp=B, logHR_S=s_eff, se_S=s_se, logHR_T=t_eff, se_T=t_se, class=sample(classes, n, TRUE))
}
